# ═══════════════════════════════════════════════════════════════════
# Frontend (Vite) — public, ships to browser
# ═══════════════════════════════════════════════════════════════════

# LINE LIFF App ID (from LINE Developer Console). Format: <channel_id>-<liff_id>
# IC 高雄: 1656533531-U5OvwB62
VITE_LIFF_ID=

# Backend API URL (leave empty for dev — Vite proxies /api to localhost:3001)
VITE_API_URL=

# ═══════════════════════════════════════════════════════════════════
# Backend (server/) — secrets, NEVER commit values, only set in Zeabur
# ═══════════════════════════════════════════════════════════════════

# Phase 3: LIFF id_token verification
# Get from LINE Developer Console → LIFF channel → Basic info → Channel ID
LINE_CHANNEL_ID=

# Phase 2: admin reset endpoint guard
ADMIN_TOKEN=

# Phase 4: dynamic-QR ticket verification chain (paired with ickh-qrcode-generator)
QR_GENERATOR_URL=
VERIFY_SECRET=

# ─── B-plan: LINE Messaging API for table flow ───────────────────────
# IC 高雄 LINE 官方帳號(認證帳號)
# Channel ID: 1656533531
# Channel Secret: get from LINE Developer Console → Messaging API → Basic settings
LINE_MESSAGING_CHANNEL_SECRET_KH=
# Channel Access Token (long-lived):
#   LINE Console → Messaging API tab → "Channel access token (long-lived)" → Issue
LINE_MESSAGING_ACCESS_TOKEN_KH=

# Game LIFF deep link (push 訊息按鈕跳的 URL)
GAME_LIFF_ID=
GAME_BASE_URL=

# ─── Future (when IC Taipei joins) ────────────────────────────────────
# LINE_MESSAGING_CHANNEL_SECRET_TPE=
# LINE_MESSAGING_ACCESS_TOKEN_TPE=

# ─── DB ──────────────────────────────────────────────────────────────
# Where sql.js writes the SQLite snapshot. Default = server/game.db
DATABASE_PATH=
NODE_ENV=
